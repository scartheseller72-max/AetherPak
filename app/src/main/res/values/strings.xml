    <!-- Capability copy (honest) -->
    <string name="cap_root_title">Root access — full backup</string>
    <string name="cap_root_desc">A real superuser shell can read and write private app data (/data/data), fix ownership and SELinux labels. This is the only mode that produces a complete backup including user data.</string>
    <string name="cap_shizuku_title">Shizuku access — partial backup</string>
    <string name="cap_shizuku_desc">Shizuku runs as the ADB shell user (UID 2000). The Android sandbox prevents it from reading another app’s private /data/data directory, so private app data CANNOT be backed up. APK install, OBB and external/shared data still work.</string>
    <string name="cap_none_title">No access</string>
    <string name="cap_none_desc">No root or Shizuku backend is available. Grant one in Access Setup to enable backups.</string>

    <string name="banner_shizuku_only">Shizuku mode: private app data is unavailable. Backups will be partial (APK + OBB + external data only).</string>
    <string name="toggle_private_disabled_reason">Private data requires Root. The current access mode (Shizuku) cannot read /data/data.</string>

